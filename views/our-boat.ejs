    <style>
        .hero-section {
            padding-top: 120px; padding-bottom: 60px;
            background: radial-gradient(circle at top, #2a2a2a 0%, var(--bg-dark) 70%);
        }

        .section-title {
            font-family: var(--font-display); font-size: 3.5rem;
            text-align: center; margin-bottom: 10px; letter-spacing: 3px;
        }

        .hud-image-wrapper { position: relative; display: inline-block; padding: 30px; margin: 40px 0; }
        .hud-corner { position: absolute; width: 50px; height: 50px; border-color: var(--bright-orange); border-style: solid; }
        .hud-top-left { top: 0; left: 0; border-width: 4px 0 0 4px; }
        .hud-top-right { top: 0; right: 0; border-width: 4px 4px 0 0; }
        .hud-bottom-left { bottom: 0; left: 0; border-width: 0 0 4px 4px; }
        .hud-bottom-right { bottom: 0; right: 0; border-width: 0 4px 4px 0; }
        
        /* jp6 style*/
        .main-boat-img {
            max-width: 100%; height: auto; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.8));
            transition: transform 0.5s ease;
        }
        .main-boat-img:hover { transform: translateY(-10px); }

        /* jp6 specs card style*/
        .spec-card {
            background-color: var(--charcoal); border: 1px solid rgba(255,255,255,0.05);
            border-bottom: 3px solid var(--pale-blue); padding: 20px; border-radius: 8px;
            text-align: center; transition: all 0.3s ease; height: 100%;
        }
        .spec-card:hover { border-bottom-color: var(--bright-orange); transform: translateY(-5px); background-color: #252525; }
        .spec-label { color: #a3a3a3; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
        .spec-value { color: var(--bright-orange); font-family: var(--font-display); font-size: 1.5rem; margin: 0; }

        /* legacy style*/
        .legacy-section { padding: 80px 0; background-color: #0a0a0a; position: relative; }
        .legacy-section::before {
            content: ''; position: absolute; top: 0; left: 50%; width: 2px; height: 100%;
            background: linear-gradient(to bottom, transparent, var(--bright-orange), transparent);
            transform: translateX(-50%); opacity: 0.3;
        }

        .legacy-row { display: flex; align-items: center; margin-bottom: 80px; }
        .legacy-row:nth-child(even) { flex-direction: row-reverse; }
        .legacy-row:nth-child(even) .legacy-text { text-align: right; padding-right: 50px; padding-left: 0; }
        .legacy-row:nth-child(odd) .legacy-text { text-align: left; padding-left: 50px; padding-right: 0; }

        .legacy-img-wrapper { flex: 1; padding: 0 40px; text-align: center; }
        .legacy-img {
            width: 100%; max-width: 400px; border-radius: 10px; border: 2px solid rgba(255,255,255,0.1);
            box-shadow: 0 10px 20px rgba(0,0,0,0.5); transition: transform 0.4s ease, border-color 0.4s ease;
        }
        .legacy-img:hover { transform: scale(1.05); border-color: var(--bright-orange); }

        .legacy-text { flex: 1; }
        .legacy-name { font-family: var(--font-display); color: white; font-size: 2rem; margin-bottom: 15px; }
        .legacy-desc { color: #d1d1d1; font-size: 1.1rem; line-height: 1.6; }

        @media (max-width: 768px) {
            .legacy-section::before { display: none; }
            .legacy-row, .legacy-row:nth-child(even) { flex-direction: column; text-align: center !important; margin-bottom: 50px; }
            .legacy-row:nth-child(even) .legacy-text, .legacy-row:nth-child(odd) .legacy-text { text-align: center; padding: 20px 0 0 0; }
            .legacy-img-wrapper { padding: 0 15px; }
        }
    </style>
</head>

