<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competition - ITS MSBT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <style>
        body, html { height: 100%; }

        .comp-hero {
            position: relative; height: 100vh; width: 100vw; display: flex; align-items: center;
            background: linear-gradient(30deg, #2c2c2c 0%, #050505 100%); overflow: hidden;
        }

        .comp-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to right, rgba(0,0,0,0.6) 20%, transparent 100%);
            z-index: 2; pointer-events: none; 
        }

        .comp-content-wrapper { position: relative; z-index: 10; pointer-events: none; }
        .comp-text-box { pointer-events: auto; padding-top: 50px; }

        .target-badge {
            display: inline-block; color: var(--bright-orange); border: 1px solid var(--bright-orange);
            padding: 5px 15px; font-family: var(--font-display); font-size: 0.8rem;
            letter-spacing: 2px; border-radius: 4px; margin-bottom: 20px;
        }

        .event-logo { display: block; max-width: 100%; width: 380px; height: auto; margin: 10px 0 30px 0; filter: drop-shadow(2px 4px 8px rgba(0,0,0,0.6)); }

        .comp-meta {
            font-size: 1.2rem; color: var(--pale-blue); margin-bottom: 30px; display: flex;
            flex-direction: column; gap: 10px; border-left: 3px solid var(--pale-blue); padding-left: 15px;
        }
        .comp-meta i { margin-right: 10px; }

        .comp-desc { font-size: 1.1rem; line-height: 1.7; color: #d1d1d1; max-width: 600px; text-align: justify; }

        .map-container {
            position: absolute; bottom: -5%; right: -5%; width: 60vw; z-index: 5; cursor: pointer;
            transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1), filter 0.6s ease;
        }
        .map-container img { width: 100%; height: auto; object-fit: contain; pointer-events: none; }
        .map-container:hover { transform: scale(1.05) translate(-20px, -20px); filter: brightness(1.1); }

        .gmaps-popup {
            position: fixed; width: 340px; background: rgba(15, 15, 15, 0.9); backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1); border-top: 3px solid var(--bright-orange);
            border-radius: 12px; padding: 15px; box-shadow: 0 25px 50px rgba(0,0,0,0.9);
            z-index: 9999; pointer-events: auto; opacity: 0; visibility: hidden;
            transform: scale(0.8) translateY(20px); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .gmaps-popup.show-popup { opacity: 1; visibility: visible; transform: scale(1) translateY(0); }

        .popup-header {
            font-family: var(--font-display); font-size: 0.9rem; margin-bottom: 10px; letter-spacing: 1px;
            color: white; display: flex; align-items: center; justify-content: space-between;
        }
        .btn-close-popup { color: #888; cursor: pointer; transition: color 0.3s; font-size: 1.2rem; }
        .btn-close-popup:hover { color: white; }
        .btn-orange { background-color: var(--bright-orange); color: white; font-weight: 600; transition: all 0.3s; }
        .btn-orange:hover { background-color: #c9521a; color: white; }

        @media (max-width: 991px) {
            .map-container { width: 130vw; right: -15%; bottom: 0; opacity: 0.5; z-index: 1; }
            .comp-content-wrapper { background: linear-gradient(to top, #000 40%, transparent 100%); z-index: 10; }
            .gmaps-popup { width: 300px; }
        }

        /* slide motion (left too right) */
        @keyframes slideInFromLeft {
            0% {
                opacity: 0;
                transform: translateX(-80px);
            }
            100% {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .comp-text-box > div, 
        .comp-text-box > img, 
        .comp-text-box > p {
            opacity: 0; 
            animation: slideInFromLeft 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        .comp-text-box .target-badge {
            animation-delay: 0.1s;
        }
        .comp-text-box .event-logo {
            animation-delay: 0.3s;
        }
        .comp-text-box .comp-meta {
            animation-delay: 0.5s;
        }
        .comp-text-box .comp-desc {
            animation-delay: 0.7s;
        }
    </style>
</head>
<body>

