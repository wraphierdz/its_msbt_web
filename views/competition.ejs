                    <div class="target-badge">UPCOMING COMPETITION</div>
                    <a href="https://solarsportone.org/" target="_blank"><img src="/assets/solar-sport-one-logo.png" alt="Solar Sport One" class="event-logo"></a>
                    
                    <div class="comp-meta">
                        <div><i class="bi bi-geo-alt-fill"></i> <strong>LOCATION:</strong> Lake Balaton, Hungary</div>
