    <script>
        const mapArea = document.getElementById('interactiveMap');
        const popup = document.getElementById('mapPopup');
        const closeBtn = document.getElementById('closePopupBtn');

        // popup map
        mapArea.addEventListener('click', (e) => {
            e.stopPropagation();
            
            const x = e.clientX - popup.offsetWidth - 15; 
            const y = e.clientY - popup.offsetHeight - 30; 
            
            popup.style.left = `${x}px`;
            popup.style.top = `${y}px`;
            
            popup.classList.add('show-popup');
        });

        // close button
        closeBtn.addEventListener('click', () => {
            popup.classList.remove('show-popup');
        });

        // close klik outside popup
        document.addEventListener('click', (e) => {
            if (!popup.contains(e.target) && !mapArea.contains(e.target)) {
                popup.classList.remove('show-popup');
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
