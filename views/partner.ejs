    <style>
        .page-header {
            padding: 120px 0 0 0; text-align: center;
            background: radial-gradient(circle at top, #1a1a1a 0%, var(--bg-dark) 70%);
        }
        .section-title {
            font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem);
            letter-spacing: 3px; margin-bottom: 10px;
        }
        .page-header .text-muted { color: #d1d1d1 !important; }

        .outline-gradient {
            padding: 3px; border-radius: 14px;
            background: linear-gradient(45deg, var(--bright-orange), var(--pale-blue), var(--bright-orange), var(--pale-blue));
            background-size: 300% 300%; transition: background-position 0.8s ease;
        }
        .outline-gradient:hover { background-position: 100% 50%; }

        /*cp style*/
        .cp-link {
            color: #aaa;
            text-decoration: none;
            font-size: 1rem;
            transition: color 0.3s;
            display: inline-block;
            margin-top: 5px;
        }
        .cp-link:hover {
            color: var(--bright-orange);
            text-shadow: 0 0 8px rgba(234, 99, 35, 0.4);
        }

        /*benefit style*/
        .benefit-stack-container {
            display: flex; justify-content: center; align-items: center;
            height: 500px; padding: 20px 0; margin-bottom: 80px;
        }
        .benefit-card-wrapper {
            position: relative; width: 250px; height: 420px; margin-left: -130px; 
            border-radius: 14px; flex-shrink: 0; box-shadow: -15px 0 25px rgba(0,0,0,0.9);
            transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1), margin-left 0.7s cubic-bezier(0.25, 1, 0.5, 1);
            cursor: pointer; z-index: 1;
        }
        .benefit-card-wrapper:first-child { margin-left: 0; }
        
        .benefit-card-inner {
            background-color: var(--card-dark); border-radius: 11px; height: 100%;
            padding: 30px 20px; display: flex; flex-direction: column; position: relative; z-index: 2;
        }
        .benefit-title { font-family: var(--font-display); font-size: 1.1rem; color: var(--bright-orange); margin-bottom: 15px; line-height: 1.3; }
        .benefit-text { color: #ccc; font-size: 0.95rem; line-height: 1.6; margin: 0; }

        .benefit-stack-container:hover .benefit-card-wrapper { filter: brightness(0.7); }
        .benefit-card-wrapper:hover {
            transform: translateY(-50px); z-index: 100;
            box-shadow: 0 30px 60px rgba(0,0,0,1); filter: brightness(1) !important;
        }
        .benefit-card-wrapper:hover ~ .benefit-card-wrapper { transform: translateX(140px); z-index: 1; }

        .recent-sponsor-logo {
            height: 250px; width: auto; max-width: 250px; object-fit: contain;
            filter: grayscale(100%) opacity(0.7); transition: all 0.4s ease; margin: 25px 20px; 
        }
        .recent-sponsor-logo:hover { filter: grayscale(0%) opacity(1); transform: scale(1.15); }        

        /*banner berjalan*/
        .marquee-wrapper {
            width: 100%; overflow: hidden; background-color: #ffffff; padding: 30px 0;
            border-top: 1px solid #ddd; border-bottom: 1px solid #ddd;
        }
        .marquee-track { display: flex; align-items: center; width: max-content; }
        .past-sponsor-logo { height: 80px; width: auto; max-width: 220px; object-fit: contain; margin: 0 30px; transition: transform 0.3s ease; }
        .past-sponsor-logo:hover { transform: scale(1.1); }
        .track-left { animation: scrollLeft 35s linear infinite; }
        .track-right { animation: scrollRight 35s linear infinite; }

        /* animasi outline gradient*/
        @keyframes scrollLeft { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @keyframes scrollRight { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }

        .form-card { background-color: var(--card-dark); padding: 40px; border-radius: 11px; height: 100%; }
        .form-control {
            background-color: #050505; border: 1px solid var(--pale-blue);
            color: white; border-radius: 6px; transition: all 0.3s;
        }
        .form-control:focus { background-color: #0a0a0a; border-color: var(--bright-orange); color: white; box-shadow: 0 0 12px rgba(234, 99, 35, 0.4); }
        .form-label.text-muted { color: var(--pale-blue) !important; font-weight: 600; letter-spacing: 1px; }
        
        .form-control[type="file"] { color: #d1d1d1; }
        .form-control[type="file"]::file-selector-button {
            background-color: #121212; color: var(--pale-blue); border: none;
            border-right: 1px solid var(--pale-blue); margin-right: 15px;
            font-weight: 600; transition: all 0.3s ease; cursor: pointer;
        }
        .form-control[type="file"]:hover::file-selector-button { background-color: var(--bright-orange); color: white; border-right-color: var(--bright-orange); }

        .btn-submit {
            background-color: var(--bright-orange); color: white; font-family: var(--font-display);
            font-size: 0.9rem; letter-spacing: 1px; padding: 12px; border: none; width: 100%;
            border-radius: 6px; transition: all 0.3s;
        }
        .btn-submit:hover { background-color: #c9521a; box-shadow: 0 5px 15px rgba(234, 99, 35, 0.4); }
        
        .success-msg {
            display: none; background-color: rgba(40, 167, 69, 0.15); border: 1px solid #28a745;
            color: #28a745; padding: 15px; border-radius: 6px; margin-top: 15px; text-align: center; font-weight: 600;
        }

        .cp-list { list-style: none; padding: 0; }
        .cp-list li { margin-bottom: 25px; display: flex; align-items: center; }
        .cp-icon { font-size: 2rem; color: var(--bright-orange); margin-right: 20px; }
        .cp-details h5 { margin: 0; font-size: 1.1rem; color: var(--pale-blue); }

        /* social media style*/
        .big-socials { padding: 50px 0; border-top: 1px dashed #333; border-bottom: 1px dashed #333; margin: 60px auto; }
        .social-item i { font-size: 3.5rem; color: var(--pale-blue); display: block; margin-bottom: 10px; transition: all 0.3s; }
        .social-item:hover { color: var(--bright-orange); }
        .social-item:hover i { color: var(--pale-blue); transform: translateY(-10px); }
        .social-item { 
            text-align: center; 
            text-decoration: none; 
            color: #aaa; 
            transition: all 0.3s; 
            
            width: 130px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        @media (max-width: 991px) {
