<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ITS MSBT Official Website</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        body, html {
            height: 100%;
            scrollbar-width: none;
        }

        .frame {
            position: relative;
            height: 100vh;
            width: 100%;
            scroll-snap-align: start;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,1) 100%);
            z-index: 1;
        }

        .content { position: relative; z-index: 2; width: 100%; }

        .tagline {
            font-family: var(--font-display); font-size: 1.2rem;
            letter-spacing: 3px; margin-top: 100px; margin-bottom: 30px;
        }

        .title-container { position: relative; width: 100%; padding: 20px 0; }
        .main-title {
            font-family: var(--font-display); font-size: 3rem;
            line-height: 1.2; margin: 0; text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
        }
        .subtitle {
            margin-top: 20px; font-size: 1.1rem; font-weight: 400;
            color: #d1d1d1; max-width: 700px; margin-left: auto; margin-right: auto;
        }

        .video-frame {
            border-radius: 12px; overflow: hidden; background-color: #000;
            transition: transform 0.4s ease;
        }
        .video-frame:hover { transform: scale(1.03); }

        .bg-frame-1 { background-image: url('/assets/thumbnail.jpg'); }
        .bg-frame-2 { background-image: url('/assets/brief.jpg'); }
        .bg-frame-3 {
            background: radial-gradient(circle at center, #2F2F2F 0%, #050505 100%);
            background-image: radial-gradient(#444 1px, transparent 1px);
            background-size: 30px 30px;
        }
        .bg-frame-4 { background-color: #030303; }

        .center-content {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%); z-index: 10;
        }
        .achievement-title {
            font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4.5rem);
            color: white; text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
            margin: 0; letter-spacing: 5px;
        }

        .achv-wrapper {
            position: absolute; z-index: 5; opacity: 0;
            transform: translateY(80px) scale(0.8);
            transition: all 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .pos-1 { top: 15%; left: 8%; }
        .pos-2 { top: 15%; right: 8%; }
        .pos-3 { bottom: 15%; left: 12%; }
        .pos-4 { bottom: 15%; right: 12%; }
        .pos-5 { bottom: 5%; left: 50%; margin-left: -115px; }

        .achv-card {
            width: 230px; background: linear-gradient(135deg, var(--bright-orange) 0%, #a84111 100%);
            border-radius: 12px; padding: 20px 15px; box-shadow: 0 15px 25px rgba(0,0,0,0.5);
            border: 2px solid #fff; position: relative; text-align: center;
        }
        .corner-badge {
            position: absolute; top: -15px; left: -15px; background-color: white;
            color: var(--bright-orange); font-family: var(--font-display);
            font-size: 1.2rem; padding: 5px 12px; transform: rotate(-15deg);
            border-radius: 5px; box-shadow: 2px 2px 10px rgba(0,0,0,0.4);
        }
        .achv-name { font-family: var(--font-display); font-size: 1.1rem; color: white; margin: 10px 0; }
        .achv-img {
            width: 100%; height: 110px; object-fit: cover; border-radius: 6px;
            margin-bottom: 10px; border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }
        .achv-desc { font-size: 0.85rem; margin: 0; color: #f1f1f1; line-height: 1.3; }

        .achv-accent-line {
            width: 0px; height: 3px; background-color: var(--bright-orange);
            box-shadow: 0 0 12px rgba(234, 99, 35, 0.8); margin: 15px auto;
            border-radius: 2px; transition: width 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.5s;
        }
        .achv-center-text {
            color: #b0b0b0; font-size: 1.05rem; max-width: 450px; margin: 0 auto;
            line-height: 1.5; opacity: 0; transform: translateY(20px); transition: all 0.8s ease 0.7s;
        }

        .show-achievements .achv-accent-line { width: 100px; }
        .show-achievements .achv-center-text { opacity: 1; transform: translateY(0); }
        .show-achievements .pos-1 { opacity: 1; transform: translateY(0) scale(1); transition-delay: 0.1s; }
        .show-achievements .pos-2 { opacity: 1; transform: translateY(0) scale(1); transition-delay: 0.3s; }
        .show-achievements .pos-3 { opacity: 1; transform: translateY(0) scale(1); transition-delay: 0.5s; }
        .show-achievements .pos-4 { opacity: 1; transform: translateY(0) scale(1); transition-delay: 0.7s; }
        .show-achievements .pos-5 { opacity: 1; transform: translateY(0) scale(1); transition-delay: 0.9s; }

        .sponsor-logo {
            height: 300px; width: auto; max-width: 200px; object-fit: contain;
            filter: grayscale(100%) opacity(0.6); transition: all 0.4s ease; cursor: pointer;
        }
        .sponsor-logo:hover { filter: grayscale(0%) opacity(1); transform: scale(1.1); }

        @media (max-height: 850px) and (min-width: 992px) {
            .achievement-title { font-size: 3.5rem; }
            .show-achievements .pos-1, .show-achievements .pos-2, .show-achievements .pos-3, .show-achievements .pos-4, .show-achievements .pos-5 { transform: translateY(0) scale(0.8); }
            .pos-1 { top: 5%; left: 2%; } .pos-2 { top: 5%; right: 2%; }
            .pos-3 { bottom: 5%; left: 5%; } .pos-4 { bottom: 5%; right: 5%; } .pos-5 { bottom: -2%; }
            .wave-animation-container { margin-top: 5px; }
        }
        @media (max-width: 768px) { .sponsor-logo { height: 45px; max-width: 120px; } }
        @media (max-width: 991px) {
            .cards-container { display: flex; flex-direction: column; align-items: center; gap: 20px; height: 100vh; overflow-y: auto; padding: 120px 0 50px 0; }
            .achv-wrapper { position: relative; top: auto !important; left: auto !important; right: auto !important; bottom: auto !important; margin: 0; }
            .center-content { top: 80px; transform: translateX(-50%); }
        }
    </style>

</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid px-5">
            <a class="navbar-brand text-white" href="#" style="font-family: var(--font-display); font-size: 1.5rem;">
